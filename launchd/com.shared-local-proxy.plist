<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.shared-local-proxy</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/local/bin/docker</string>
      <string>compose</string>
      <string>up</string>
      <string>-d</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ayoub/projects/infra/local-proxy</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/shared-local-proxy.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/shared-local-proxy.stderr.log</string>
  </dict>
</plist>
